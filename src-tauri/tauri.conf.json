{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agenTerm",
  "version": "0.1.0",
  "identifier": "io.agenterm.desktop",
  "build": {
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "beforeDevCommand": "npm --prefix ../frontend run dev -- --host",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "agenTerm",
        "width": 1500,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.png"
    ]
  }
}
